---
import '@/styles/global.css';
import Header from '@/components/Header.astro';
import SkipLink from '@/components/SkipLink.astro';
import Footer from '@/components/Footer.astro';
import CaseAdRotateInit from '@/components/CaseAdRotateInit.astro';
import GlobalBottomAffiliateStrip from '@/components/GlobalBottomAffiliateStrip.astro';
import SiteSectionAds from '@/components/SiteSectionAds.astro';
import type { SectionPage } from '@/lib/section-page';
import home from '@/data/spawn-home.json';

const b = home.brand;
const id = b?.identity ?? {};
const dmeta = (home as { defaultMetaDescription?: string }).defaultMetaDescription || '';

// Analytics auto-injection — reads niche_spec.analytics.ga_measurement_id at
// build time. When set, emits the gtag.js snippet so /analytics dashboard
// can flip from not_connected to live without code changes.
const ga = (home as { analytics?: { ga_measurement_id?: string; ga_property_id?: string; search_console_property?: string } }).analytics;
const gaMeasurementId = (ga?.ga_measurement_id || '').trim();

export interface Props {
  title: string;
  description?: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
  ogType?: 'website' | 'article' | 'product';
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleAuthor?: string;
  articleSection?: string;
  articleTags?: string[];
  /** Overrides og/twitter title only (e.g. Pinterest cardTitle hook). */
  ogTitle?: string;
  /** Sitewide ad spine (omit on longform — LongformPageShell owns top/footer promos) */
  sectionAds?: SectionPage | false;
  /** Tighter header ad on list/index pages (no ornament) */
  sectionAdsCompact?: boolean;
  /** When false, only render header band (home keeps footer ad before newsletter) */
  sectionAdsFooter?: boolean;
}

const {
  title,
  description = dmeta,
  image,
  canonical,
  noindex = false,
  ogType = 'website',
  articlePublishedTime,
  articleModifiedTime,
  articleAuthor = b.fullName,
  articleSection,
  articleTags = [],
  ogTitle,
  sectionAds = false,
  sectionAdsCompact = false,
  sectionAdsFooter = true,
} = Astro.props;

const siteUrl = (import.meta.env.SITE as string | undefined)?.replace(/\/$/, '') || '';
const hero = home.homepage.heroImageUrl;
const defaultOg = (image && image.length) ? image : (hero && hero.length ? hero : '/og-default.png');
const og = defaultOg;
const isAbs = (u: string) => /^https?:\/\//i.test(u);
const fullTitle = title.includes(b.fullName) ? title : `${title} | ${b.fullName}`;
const shareTitle = ogTitle?.trim() || fullTitle;
const canonicalUrl = canonical ?? (siteUrl ? new URL(Astro.url.pathname, siteUrl + '/').toString() : Astro.url.href);
const ogImageUrl = isAbs(og) ? og : siteUrl ? new URL(og, siteUrl + '/').toString() : og;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    {id.fontCssHref ? <link rel="stylesheet" href={id.fontCssHref} /> : null}

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={shareTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={b.fullName} />

    {ogType === 'article' && (
      <>
        {articlePublishedTime && <meta property="article:published_time" content={articlePublishedTime} />}
        {articleModifiedTime && <meta property="article:modified_time" content={articleModifiedTime} />}
        <meta property="article:author" content={articleAuthor} />
        {articleSection && <meta property="article:section" content={articleSection} />}
        {articleTags.map((t) => <meta property="article:tag" content={t} />)}
      </>
    )}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={shareTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="alternate" type="application/rss+xml" title={b.fullName} href="/rss.xml" />

    {(() => {
      const url = import.meta.env.PUBLIC_NEWSLETTER_EMBED_URL;
      if (typeof url === 'string' && url.includes('subscribe-forms.beehiiv.com')) {
        return <script async src="https://subscribe-forms.beehiiv.com/embed.js"></script>;
      }
      return null;
    })()}

    {/* Google Analytics 4 — auto-injected when niche_spec.analytics.ga_measurement_id is set */}
    {gaMeasurementId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>
        <script set:html={`window.dataLayer = window.dataLayer || []; function gtag(){dataLayer.push(arguments);} gtag('js', new Date()); gtag('config', '${gaMeasurementId}', { 'anonymize_ip': true });`}></script>
      </>
    )}
  </head>
  <body class="min-h-screen flex flex-col site-page-bg texture-paper">
    <SkipLink />
    <Header />
    {sectionAds && (
      <div class="site-top-ad-band border-b border-cream-200/70 bg-cream-50/95 py-0">
        <SiteSectionAds page={sectionAds} variant="header" compact={sectionAdsCompact} />
      </div>
    )}
    <main id="main-content" class="flex-1" tabindex="-1">
      <slot />
      {sectionAds && sectionAdsFooter && <SiteSectionAds page={sectionAds} variant="footer" />}
    </main>
    <GlobalBottomAffiliateStrip />
    <CaseAdRotateInit />
    <Footer />
      <script is:inline>
      (function(){try{window.dataLayer=window.dataLayer||[];function emit(n,p){window.dataLayer.push(Object.assign({event:n},p));if(typeof window.gtag==='function')window.gtag('event',n,p)}function txt(a){var t=(a.textContent||'').replace(/\s+/g,' ').trim();return t.length>80?t.slice(0,80):t}document.addEventListener('click',function(e){var el=e.target;if(!el||!el.closest)return;var a=el.closest('a[href]');if(!a)return;var raw=a.getAttribute('href');if(!raw)return;var u;try{u=new URL(raw,location.href)}catch(_){return}if(u.protocol!=='http:'&&u.protocol!=='https:')return;var href=u.href,domain=u.hostname,rel=(a.getAttribute('rel')||'').toLowerCase(),aff=rel.indexOf('sponsored')>=0||href.toLowerCase().indexOf('amazon.')>=0,base={link_url:href,link_domain:domain,link_text:txt(a),page_path:location.pathname};if(aff){emit('affiliate_click',base);return}if(domain&&domain!==location.hostname)emit('outbound_click',base)},true)}catch(_){}})();
    </script>
  </body>
</html>
