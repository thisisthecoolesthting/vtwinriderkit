---
import { getEntry } from 'astro:content';

export interface Props {
  authorSlug: string;
  publishedAt: Date | string;
  reviewedAt?: Date | string;
  /** footer = below article body; default = legacy above-body strip */
  variant?: 'default' | 'footer';
}

const { authorSlug, publishedAt, reviewedAt, variant = 'default' } = Astro.props;

const author = await getEntry('authors', authorSlug);
if (!author) {
  throw new Error(`Author not found: ${authorSlug}`);
}

const pubDate = new Date(publishedAt);
const revDate = reviewedAt ? new Date(reviewedAt) : null;
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const isFooter = variant === 'footer';
---

<div
  class:list={[
    'flex items-center gap-3 not-prose',
    isFooter
      ? 'mt-6 pt-5 border-t border-cream-200/80'
      : 'py-5 border-y border-cream-200/70 my-6',
  ]}
>
  <a href={`/authors/${author.slug}/`} class="block shrink-0 no-underline">
    <img
      src={author.data.photoUrl}
      alt={author.data.name}
      loading="lazy"
      width={isFooter ? 48 : 56}
      height={isFooter ? 48 : 56}
      class:list={[
        'rounded-full object-cover ring-2 ring-cream-200/80 !my-0',
        isFooter ? 'w-12 h-12' : 'w-14 h-14',
      ]}
    />
  </a>
  <div class="flex-1 min-w-0 leading-snug">
    <p class="text-sm text-ink-900 !mt-0 !mb-0.5">
      By
      <a
        href={`/authors/${author.slug}/`}
        class="font-semibold text-ink-900 hover:text-terracotta-600 transition-colors no-underline"
      >{author.data.name}</a>
      <span class="text-ink-500 font-normal"> · {author.data.role}</span>
    </p>
    <p class="text-xs text-ink-500 !mt-0">
      Published {fmt(pubDate)}
      {revDate && <> · Last reviewed {fmt(revDate)}</>}
    </p>
  </div>
</div>
