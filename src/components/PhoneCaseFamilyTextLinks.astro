---
/**
 * Phone-case family cross-links — only for phone-case niche sites.
 */
import { CASE_AD_STORES } from '@/data/case-ad-stores';
import home from '@/data/spawn-home.json';

export interface Props {
  placement?: string;
  compact?: boolean;
}

const { placement = 'text-links', compact = false } = Astro.props;
const slug = (home as { slug?: string }).slug ?? '';
const showFamily = slug === 'phonecasesforall' || slug === 'refillwatch';
if (!showFamily) {
  return null;
}
const aff = import.meta.env.PUBLIC_ASSOCIATE_TAG ?? 'vtwinriderkit-20';
---

<nav
  class:list={[
    'not-prose rounded-2xl border border-cream-200 bg-cream-50/80',
    compact ? 'px-3 py-3 text-xs' : 'px-4 py-4 sm:px-5 sm:py-5 text-sm',
  ]}
  aria-label="Phone case shops in our family of brands"
>
  <p class="font-mono text-[10px] tracking-[0.14em] uppercase text-terracotta-600 mb-3 !m-0">
    From our family of brands
  </p>
  <ul class="flex flex-wrap gap-x-4 gap-y-2 list-none p-0 m-0">
    {CASE_AD_STORES.map((store) => (
      <li>
        <a
          href={`https://www.amazon.com/s?k=${encodeURIComponent(store.keyword)}&tag=${aff}&utm_source=site&utm_medium=text&utm_campaign=family&utm_content=${placement}`}
          class="text-ink-700 hover:text-terracotta-600 underline-offset-2 hover:underline"
          rel="sponsored noopener"
          target="_blank"
        >
          {store.label}
        </a>
      </li>
    ))}
  </ul>
</nav>
