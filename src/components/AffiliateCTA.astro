---
// Drop-in CTA for product reviews. Used inline within Markdown via:
//   <AffiliateCTA asin="B0XXXXXXXX" label="Check current price on Amazon" />
//
// If `url` is omitted, we build it from ASIN using your Associate tag.
export interface Props {
  asin?: string;
  url?: string;
  label?: string;
}
const ASSOCIATE_TAG = import.meta.env.PUBLIC_ASSOCIATE_TAG ?? 'vtwinriderkit-20';
const { asin, url, label = 'Check price on Amazon' } = Astro.props;
const href = url ?? (asin
  ? `https://www.amazon.com/dp/${asin}?tag=${ASSOCIATE_TAG}&linkCode=ll1`
  : '#');
---
<p class="my-6 text-center">
  <a
    href={href}
    rel="nofollow sponsored noopener"
    target="_blank"
    class="btn-primary no-underline"
  >
    {label} →
  </a>
</p>
