---

import ArticleSidebar from '@/components/ArticleSidebar.astro';

import ArticleOrnamentDivider from '@/components/ArticleOrnamentDivider.astro';

import AuthorByline from '@/components/AuthorByline.astro';

import MedicalDisclaimer from '@/components/MedicalDisclaimer.astro';

import PhoneCaseFamilyTextLinks from '@/components/PhoneCaseFamilyTextLinks.astro';

import TopPicksBlock from '@/components/TopPicksBlock.astro';

import type { CollectionEntry } from 'astro:content';



export interface Props {

  title: string;

  heroImage?: string;

  authorSlug: string;

  publishedAt: Date | string;

  reviewedAt?: Date | string;

  medicalBeforeBody?: boolean;

  medicalAfterBody?: boolean;

  relatedProducts?: CollectionEntry<'products'>[];
  /** Layer 3 pin layout id (niche template palette, stable per slug). */
  pinTemplate?: string;

}



const {

  title,

  heroImage,

  authorSlug,

  publishedAt,

  reviewedAt,

  medicalBeforeBody = false,

  medicalAfterBody = false,

  relatedProducts = [],
  pinTemplate = 'default',

} = Astro.props;

---



<div class="max-w-site mx-auto px-3 sm:px-6 lg:px-8 py-4 md:py-14 pb-8 md:pb-16">

  <div class="longform-layout flex flex-col lg:flex-row gap-4 lg:gap-8 items-start lg:items-start">

    <ArticleSidebar />



    <article
      class="min-w-0 flex-1 w-full max-w-none article-longform"
      data-pin-template={pinTemplate}
    >

      <div class="article-longform-inner mx-auto w-full max-w-3xl">

        <ArticleOrnamentDivider />



        <header class="mb-4 md:mb-6 text-left md:text-center">

          <h1 class="article-title-display font-display text-[1.65rem] sm:text-3xl md:text-4xl text-ink-900 mb-0 !mt-0 leading-[1.15] tracking-tight break-words">

            {title}

          </h1>

        </header>



        {medicalBeforeBody && (

          <div class="mb-6 text-left">

            <MedicalDisclaimer />

          </div>

        )}



        {heroImage && (

          <figure class="mb-8 md:mb-10 mx-auto max-w-2xl">

            <img

              src={heroImage}

              alt={title}

              loading="eager"

              fetchpriority="high"

              decoding="async"

              class="w-full h-auto rounded-3xl object-cover aspect-[16/9] max-h-[520px] shadow-soft"

            />

          </figure>

        )}



        <div class="article-body-wide article-body-performance prose prose-base md:prose-lg prose-ink max-w-none text-left">
          <slot />
        </div>




        <div class="mt-8 text-left">

          <AuthorByline

            authorSlug={authorSlug}

            publishedAt={publishedAt}

            reviewedAt={reviewedAt}

          />

        </div>



        {medicalAfterBody && (

          <div class="mb-8 text-left">

            <MedicalDisclaimer />

          </div>

        )}



        <div class="my-8">

          <PhoneCaseFamilyTextLinks placement="longform-after-author" />

        </div>



        {relatedProducts.length >= 1 && (

          <div id="top-picks" class="not-prose mt-8">

            <TopPicksBlock products={relatedProducts} />

          </div>

        )}

      </div>

    </article>

  </div>

</div>



<style>
  /* Do not clip position:sticky on the sidebar rail */
  .longform-layout {
    overflow: visible;
  }


  .article-longform .article-body-wide {

    font-size: 0.9375rem;

    line-height: 1.65;

  }

  @media (min-width: 768px) {

    .article-longform .article-body-wide {

      font-size: 1rem;

      line-height: 1.7;

    }

  }

  .article-longform .article-body-wide :global(p),

  .article-longform .article-body-wide :global(li),

  .article-longform .article-body-wide :global(td),

  .article-longform .article-body-wide :global(th) {

    max-width: none;

  }

  .article-longform .article-body-wide :global(h2) {

    font-size: 1.2rem;

    margin-top: 1.6em;

    margin-bottom: 0.45em;

    line-height: 1.3;

  }

  .article-longform .article-body-wide :global(h3) {

    font-size: 1.05rem;

    margin-top: 1.35em;

    margin-bottom: 0.35em;

    line-height: 1.35;

  }

  .article-longform .article-body-wide :global(h4) {

    font-size: 0.98rem;

  }

  .article-longform .article-body-wide :global(table) {

    font-size: 0.875rem;
    display: block;
    max-width: 100%;
    overflow-x: auto;

  }

  .article-longform .article-body-wide :global(.amazon-inline-card) {
    max-width: 100%;
  }

  .article-longform .article-body-wide :global(.amazon-inline-card__title) {
    word-break: break-word;
  }

  .article-longform .article-body-wide :global(blockquote) {

    font-size: 0.92em;

  }

</style>

