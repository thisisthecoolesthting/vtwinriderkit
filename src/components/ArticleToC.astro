---
export interface Props {
  /** Inside ArticleSidebar — no second sticky column. */
  embedded?: boolean;
  /** Full heading list (h2 + h3), no collapsed height cap. */
  expanded?: boolean;
}

const { embedded = false, expanded = false } = Astro.props;
---

<nav
  id="article-toc"
  aria-label="Table of contents"
  class:list={[
    embedded ? 'block w-full min-w-0' : 'hidden xl:block sticky top-24 self-start w-52 flex-shrink-0',
    expanded && 'article-toc--expanded',
  ]}
>
  <p class="font-mono text-[10px] tracking-[0.16em] uppercase text-terracotta-600 mb-2">Page map</p>
  <a
    id="toc-jump"
    href="#top-picks"
    class="hidden mb-2 block w-full text-center bg-terracotta-500 hover:bg-terracotta-600
           text-cream-50 font-mono text-[10.5px] tracking-[0.1em] uppercase
           px-3 py-2 rounded-full transition-colors no-underline"
  >
    ↓ Jump to picks
  </a>
  <ol
    id="toc-list"
    class:list={[
      'space-y-0.5 text-sm text-ink-700 pr-1',
      expanded ? 'toc-list--expanded' : 'toc-list-scroll',
    ]}
  ></ol>
</nav>

<style>
  .toc-list-scroll {
    max-height: min(52vh, 28rem);
    overflow-y: auto;
  }

  .toc-list--expanded {
    max-height: none;
    overflow: visible;
  }

  .article-toc--expanded :global(a) {
    font-size: 0.8125rem;
    line-height: 1.35;
  }

  .article-toc--expanded :global(li.toc-h3 a) {
    font-size: 0.75rem;
    padding-left: 0.75rem;
    color: rgb(var(--ink-600) / 1);
  }
</style>

<script>
(function () {
  const list = document.getElementById('toc-list');
  const jump = document.getElementById('toc-jump');
  const nav = document.getElementById('article-toc');
  if (!list || !nav) return;

  const expanded = nav.classList.contains('article-toc--expanded');

  if (document.getElementById('top-picks')) jump?.classList.remove('hidden');

  const article = document.querySelector('article.article-longform, article');
  const headings = article
    ? Array.from(article.querySelectorAll(expanded ? 'h2, h3' : 'h2'))
    : [];

  headings.forEach((h, i) => {
    if (!h.id) h.id = `s${i}`;
    const li = document.createElement('li');
    if (h.tagName === 'H3') li.className = 'toc-h3';
    const a = document.createElement('a');
    a.href = `#${h.id}`;
    a.textContent = h.textContent ?? '';
    a.className =
      'block py-0.5 px-2 rounded transition-colors no-underline leading-snug ' +
      'text-ink-600 hover:text-terracotta-600 hover:bg-cream-100';
    li.appendChild(a);
    list.appendChild(li);
  });

  if (headings.length === 0) {
    const empty = document.createElement('li');
    empty.className = 'text-xs text-ink-500 px-2';
    empty.textContent = 'Sections appear as you scroll.';
    list.appendChild(empty);
  }

  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        const lnk = list.querySelector(`a[href="#${e.target.id}"]`);
        if (lnk) {
          lnk.classList.toggle('text-terracotta-600', e.isIntersecting);
          lnk.classList.toggle('font-semibold', e.isIntersecting);
        }
      });
    },
    { rootMargin: '-20% 0px -70% 0px' }
  );

  headings.forEach((h) => io.observe(h));
})();
</script>
