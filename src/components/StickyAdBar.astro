---
/**
 * Mobile-only sticky phone-case promo (bottom). Desktop uses sidebar / section ads.
 */
import CaseAdSlot from '@/components/CaseAdSlot.astro';
import home from '@/data/spawn-home.json';

const promo = (home as { distribution?: { phone_case_promo?: { enabled?: boolean } } }).distribution
  ?.phone_case_promo;
const enabled = promo?.enabled !== false;
---

{enabled && (
  <div
    id="sticky-ad-bar"
    class="md:hidden fixed bottom-0 inset-x-0 z-50 px-2 pb-[max(0.5rem,env(safe-area-inset-bottom))] pointer-events-none"
    data-sticky-ad-bar
  >
    <div class="pointer-events-auto max-w-lg mx-auto relative">
      <CaseAdSlot size="320x50" placement="mobile-sticky-bottom" />
      <button
        type="button"
        aria-label="Dismiss ad"
        data-sticky-ad-dismiss
        class="absolute -top-1 right-1 z-10 w-7 h-7 rounded-full bg-ink-900/90 text-cream-50 text-sm leading-none shadow-soft"
      >
        ×
      </button>
    </div>
  </div>
)}

<script>
  (function () {
    const bar = document.querySelector('[data-sticky-ad-bar]');
    const btn = document.querySelector('[data-sticky-ad-dismiss]');
    if (!bar || !btn) return;
    btn.addEventListener('click', () => {
      bar.style.display = 'none';
      document.documentElement.classList.remove('has-mobile-sticky-ad');
    });
    document.documentElement.classList.add('has-mobile-sticky-ad');
  })();
</script>
