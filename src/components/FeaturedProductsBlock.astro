---
// Rendered at the bottom of articles + pillars. Takes a list of products
// (resolved via getRelatedProductsFromBody) and shows a rounded card grid,
// each with a prominent "Check price on Amazon →" affiliate button.

import type { CollectionEntry } from 'astro:content';
import { amazonAffiliateUrl } from '@/utils/related-products';

export interface Props {
  products: CollectionEntry<'products'>[];
  title?: string;
  kicker?: string;
}

const {
  products,
  title = 'Shop the picks mentioned above',
  kicker = 'Featured in this article',
} = Astro.props;

const associateTag = import.meta.env.PUBLIC_ASSOCIATE_TAG ?? 'vtwinriderkit-20';
---

{products && products.length > 0 && (
  <section class="not-prose my-12 md:my-16">
    <div class="bg-cream-100 rounded-[2rem] md:rounded-[2.5rem] shadow-soft p-6 md:p-10">
      <div class="mb-6 md:mb-8">
        <p class="text-terracotta-600 text-xs uppercase tracking-[0.22em] font-semibold mb-2">
          {kicker}
        </p>
        <h2 class="font-display text-2xl md:text-3xl text-ink-900 !mt-0 leading-tight">
          {title}
        </h2>
        <p class="text-sm text-ink-500 mt-2 leading-relaxed">
          We earn a small commission if you buy through these links, at no extra cost to you.
        </p>
      </div>

      <div class="grid gap-4 md:gap-5 md:grid-cols-2">
        {products.map((p) => (
          <article class="bg-white rounded-2xl border border-cream-200/60 p-4 md:p-5 flex gap-4 items-center shadow-soft hover:shadow-soft-lg transition-shadow duration-300">
            <a
              href={`/products/${p.slug}/`}
              class="block shrink-0 w-20 md:w-24 aspect-square rounded-xl overflow-hidden bg-cream-100 no-underline"
            >
              {p.data.imageUrl ? (
                <img
                  src={p.data.imageUrl}
                  alt={p.data.title}
                  loading="lazy"
                  class="w-full h-full object-contain p-1.5"
                />
              ) : (
                <div class="w-full h-full bg-cream-200"></div>
              )}
            </a>
            <div class="flex-1 min-w-0">
              <h3 class="font-display text-base md:text-lg text-ink-900 !mt-0 leading-snug line-clamp-2">
                <a
                  href={`/products/${p.slug}/`}
                  class="no-underline hover:text-terracotta-600 transition-colors duration-200"
                >
                  {p.data.title}
                </a>
              </h3>
              <div class="flex items-center gap-3 text-xs text-ink-500 mt-1.5">
                {p.data.price && <span class="font-medium">${p.data.price.toFixed(2)}</span>}
                {p.data.rating && <span>★ {p.data.rating.toFixed(1)}</span>}
              </div>
              <a
                href={amazonAffiliateUrl(p, associateTag)}
                rel="nofollow sponsored noopener"
                target="_blank"
                class="btn-primary text-xs md:text-sm px-4 py-2 mt-3"
              >
                Check price on Amazon →
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
)}
