---
/** Inner-page hero band — homepage color profile (cream + red/blue glow), not ink-900. */
export interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'center' | 'left';
}

const { eyebrow, title, description, align = 'center' } = Astro.props;
const alignClass = align === 'left' ? 'text-left mx-0' : 'text-center mx-auto';
---

<section class="page-intro-band border-b border-cream-200/80">
  <div class="max-w-site mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-14">
    <div class:list={['max-w-3xl', alignClass]}>
      {eyebrow && <p class="section-eyebrow mb-2">{eyebrow}</p>}
      <h1 class="font-display text-3xl md:text-4xl lg:text-5xl text-ink-900 leading-tight !mt-0 text-balance">
        {title}
      </h1>
      {description && (
        <p
          class:list={[
            'text-ink-700 text-base md:text-lg leading-relaxed mt-4 max-w-[42ch]',
            align === 'center' && 'mx-auto',
          ]}
        >
          {description}
        </p>
      )}
    </div>
  </div>
</section>
