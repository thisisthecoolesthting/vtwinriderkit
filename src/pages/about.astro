---
import CompliantLayout from '@/layouts/CompliantLayout.astro';
import PageIntro from '@/components/PageIntro.astro';
import NewsletterForm from '@/components/NewsletterForm.astro';
import home from '@/data/spawn-home.json';

const about = (home as { about?: { headline?: string; body?: string } }).about;
const headline = about?.headline ?? 'Why V-Twin Rider Kit exists';
const body =
  about?.body ??
  'We ride American cruisers and baggers and organize Amazon-buyable touring gear, garage tools, and road-trip kits with honest comparisons.';
---

<CompliantLayout
  title="About"
  description="What V-Twin Rider Kit is, why it exists, and how we choose gear for V-twin and cruiser riders."
  sectionAds="about"
>
  <PageIntro
    eyebrow="About V-Twin Rider Kit"
    title={headline}
    description="Independent gear checklists for American V-twin and cruiser riders — not affiliated with Harley-Davidson or any motorcycle manufacturer."
  />

  <section class="max-w-site mx-auto px-4 sm:px-6 lg:px-8 pb-10 md:pb-14">
    <article class="content-panel max-w-3xl mx-auto prose prose-lg prose-ink">
      <p class="!mt-0">{body}</p>

      <h2>How we pick gear</h2>
      <p>
        We prioritize scenario fit (weekend ride, touring, garage maintenance),
        verified Amazon listings with strong review signals, and gear we would
        pack on our own bikes. We decline paid placements and do not let
        commissions change sort order.
      </p>

      <h2>How we make money</h2>
      <p>
        <strong>As an Amazon Associate I earn from qualifying purchases.</strong>
        Revenue is Amazon Associates only. See our full
        <a href="/disclosure">partner disclosure</a>.
      </p>

      <h2>Trademark notice</h2>
      <p>
        V-Twin Rider Kit is not affiliated with, endorsed by, or sponsored by
        Harley-Davidson, Inc. or any motorcycle manufacturer. Product names and
        trademarks belong to their owners. Always confirm fitment with the seller
        before you buy.
      </p>

      <h2>Get in touch</h2>
      <p>
        Questions, corrections, or fitment notes:
        <a href="mailto:hello@vtwinriderkit.org">hello@vtwinriderkit.org</a>.
      </p>
    </article>
  </section>

  <section class="section-band-sage">
    <div class="max-w-site mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-14">
      <div class="content-panel-muted max-w-3xl mx-auto">
        <NewsletterForm variant="hero" />
      </div>
    </div>
  </section>
</CompliantLayout>
