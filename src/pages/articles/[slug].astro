---
import BaseLayout from '@/layouts/BaseLayout.astro';
import LongformPageShell from '@/components/LongformPageShell.astro';
import EmailCapture from '@/components/EmailCapture.astro';
import NewsletterForm from '@/components/NewsletterForm.astro';
import { getCollection, getEntry } from 'astro:content';
import { getRelatedProductsFromBody } from '@/utils/related-products';
import { siteOrigin } from '@/utils/site-origin';
import home from '@/data/spawn-home.json';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => data.status !== 'draft');
  return articles.map((a) => ({
    params: { slug: a.slug },
    props: { entry: a },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const b = home.brand;
const nl = home.newsletter ?? { title: '', subtitle: '' };
const siteYmyl =
  (home as { editorial?: { ymyl?: boolean } }).editorial?.ymyl === true ||
  (home as { persona?: { ymyl?: boolean } }).persona?.ymyl === true;
const o = siteOrigin();
const editorialAuthor = (home as { editorial?: { author_slug?: string } }).editorial?.author_slug;
const defSlug =
  editorialAuthor || (home as { defaultAuthorSlug?: string }).defaultAuthorSlug || '_default';
const authorSlug = entry.data.author ?? defSlug;
const author = await getEntry('authors', authorSlug);
const relatedProducts = await getRelatedProductsFromBody(entry.body);
const publishedISO = new Date(entry.data.publishedAt ?? entry.data.updatedAt ?? Date.now()).toISOString();
const modifiedISO = entry.data.updatedAt ? new Date(entry.data.updatedAt).toISOString() : undefined;
const bodyLower = (entry.body || '').toLowerCase();
const tags = (entry.data.tags || []).map((t) => t.toLowerCase());
const medicalTerms = [
  'hrt', 'hormone therapy', 'hormone replacement', 'estrogen', 'progesterone',
  'supplement', 'magnesium', 'melatonin', 'ssri', 'statin',
  'sleeping pill', 'sleep medication', 'insomnia', 'prescription',
];
const bodyHeuristic = medicalTerms.some((term) => bodyLower.includes(term));
const tagMatch = ['health', 'supplements', 'medication', 'hrt', 'hormones', 'insomnia'].some((k) =>
  tags.includes(k),
);
const customDisclaimer = (entry.data as { customDisclaimer?: boolean }).customDisclaimer === true;
const needsMedicalDisclaimer =
  siteYmyl && !customDisclaimer && (tagMatch || bodyHeuristic || siteYmyl);
const orgPub = b.fullName;
const orgUrl = o || (import.meta.env.SITE as string);
const personSchema = author
  ? {
      '@type': 'Person' as const,
      '@id': `${o}/authors/${author.slug}/#person`,
      name: author.data.name,
      url: `${o}/authors/${author.slug}/`,
      image: `${o}${author.data.photoUrl}`,
      jobTitle: author.data.role,
    }
  : { '@type': 'Organization' as const, name: orgPub, url: orgUrl };
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: entry.data.title,
  description: entry.data.metaDescription,
  datePublished: publishedISO,
  dateModified: modifiedISO ?? publishedISO,
  author: personSchema,
  publisher: { '@type': 'Organization', name: b.fullName, url: o },
  image: entry.data.heroImage ? [entry.data.heroImage] : undefined,
  mainEntityOfPage: { '@type': 'WebPage', '@id': `${o}/articles/${entry.slug}/` },
};
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.metaDescription}
  image={entry.data.heroImage}
  ogType="article"
  articlePublishedTime={publishedISO}
  articleModifiedTime={modifiedISO}
  articleAuthor={author?.data.name ?? b.fullName}
  articleTags={entry.data.tags}
  sectionAds="articles"
  sectionAdsCompact
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <LongformPageShell
    title={entry.data.title}
    heroImage={entry.data.heroImage}
    authorSlug={authorSlug}
    publishedAt={entry.data.publishedAt ?? entry.data.updatedAt}
    reviewedAt={entry.data.reviewedAt ?? entry.data.updatedAt}
    medicalAfterBody={needsMedicalDisclaimer}
    relatedProducts={relatedProducts}
  >
    <Content />
  </LongformPageShell>

  <div class="max-w-site mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    <EmailCapture title={nl.title} subtitle={nl.subtitle} />
    <NewsletterForm variant="inline" title={nl.title} subtitle={nl.subtitle} />
  </div>
</BaseLayout>
