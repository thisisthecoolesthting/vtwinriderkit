---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageIntro from '@/components/PageIntro.astro';
import { getCollection } from 'astro:content';
import home from '@/data/spawn-home.json';
import { isHeroImageAvailable } from '@/lib/hero-image';

const allArticles = await getCollection('articles', ({ data }) => data.status === 'published');
const defaultAuthorSlug = (home as { defaultAuthorSlug?: string }).defaultAuthorSlug || 'dana-wolff';

const articleData = allArticles.map((a) => ({
  slug: a.slug,
  title: a.data.title,
  excerpt: (a.data as any).excerpt || '',
  heroImage: isHeroImageAvailable(a.data.heroImage) ? (a.data.heroImage as string) : '',
  author: a.data.author ?? defaultAuthorSlug,
  subtopic: (a.data as any).subtopic || '',
  updatedAt: a.data.updatedAt ? new Date(a.data.updatedAt).toISOString() : '',
  publishedAt: a.data.publishedAt ? new Date(a.data.publishedAt).toISOString() : '',
}));

const subtopicLabels: Record<string, string> = {
  "brands": "Brands",
  "cleaning": "Cleaning",
  "diy": "DIY",
  "packaging": "Packaging",
  "personal-care": "Personal Care",
};
const description = "Tracking shrinkflation and pricing tricks so you don't have to.";
---

<BaseLayout title="Articles" description={description} sectionAds="articles" sectionAdsCompact>
  <PageIntro eyebrow="Latest from the desk" title="Articles" description={description} />

  <section class="max-w-site mx-auto px-4 sm:px-6 lg:px-8 pb-10 md:pb-14">
    {/* Filter + sort controls */}
    <div class="flex flex-wrap gap-3 mb-5 items-center">
      <div class="flex flex-wrap gap-2" id="filter-bar">
        <button
          data-filter="all"
          class="filter-btn active px-4 py-1.5 rounded-full text-sm font-medium border border-ink-300 bg-ink-900 text-white transition-colors"
        >All</button>
        {Object.entries(subtopicLabels).map(([slug, label]) => (
          <button
            data-filter={slug}
            class="filter-btn px-4 py-1.5 rounded-full text-sm font-medium border border-ink-300 bg-white text-ink-700 hover:bg-ink-100 transition-colors"
          >{label}</button>
        ))}
      </div>
      <div class="ml-auto">
        <select id="sort-select" class="text-sm border border-ink-300 rounded-full px-3 py-1.5 bg-white text-ink-700 cursor-pointer">
          <option value="newest">Newest first</option>
          <option value="oldest">Oldest first</option>
          <option value="az">A → Z</option>
          <option value="za">Z → A</option>
        </select>
      </div>
    </div>

    <p id="result-count" class="text-sm text-ink-500 mb-4"></p>

    <div id="articles-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {articleData.map((a) => (
        <a
          href={`/articles/${a.slug}`}
          data-subtopic={a.subtopic}
          data-title={a.title.toLowerCase()}
          data-date={a.updatedAt || a.publishedAt || '2026-01-01'}
          class:list={[
            'article-card group no-underline block',
            !a.heroImage && 'rounded-lg border border-cream-200 bg-white p-4 hover:border-terracotta-400 transition-colors',
          ]}
        >
          {a.heroImage && (
            <div class="rounded-lg overflow-hidden mb-3 bg-cream-200 aspect-[16/10]">
              <img
                src={a.heroImage}
                alt={a.title}
                loading="lazy"
                class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300"
              />
            </div>
          )}
          {a.subtopic && (
            <span class="inline-block text-xs font-medium text-terracotta-600 bg-terracotta-50 rounded-full px-2.5 py-0.5 mb-2">
              {subtopicLabels[a.subtopic] || a.subtopic}
            </span>
          )}
          <h2 class="font-display text-xl text-ink-900 !mt-0 leading-snug group-hover:text-terracotta-500 transition-colors">
            {a.title}
          </h2>
          {a.excerpt && <p class="text-ink-700 mt-2 text-sm line-clamp-2">{a.excerpt}</p>}
          <div class="mt-3 flex items-center gap-2 text-xs text-ink-500">
            <img
              src={`/authors/${a.author}.svg`}
              alt={a.author}
              class="w-6 h-6 rounded-full object-cover bg-cream-200"
              loading="lazy"
              onerror="this.onerror=null;this.src='/authors/dana-wolff.svg'"
            />
            {(a.updatedAt || a.publishedAt) && (
              <span>{new Date(a.updatedAt || a.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
            )}
          </div>
        </a>
      ))}
    </div>

    <p id="no-results" class="hidden text-ink-600 text-center py-12">No articles match this filter.</p>
  </section>
</BaseLayout>

<script>
  (function () {
    const grid    = document.getElementById('articles-grid');
    const noRes   = document.getElementById('no-results');
    const counter = document.getElementById('result-count');
    const cards   = Array.from(document.querySelectorAll('.article-card'));
    const sortSel = document.getElementById('sort-select');
    if (!grid || !cards.length) return;

    const params = new URLSearchParams(window.location.search);
    let activeFilter = params.get('subtopic') || params.get('cat') || 'all';
    let activeSort   = 'newest';

    function setActiveButton(filter) {
      document.querySelectorAll('.filter-btn').forEach((b) => {
        const el = b;
        const on = (el.dataset.filter || 'all') === filter;
        el.classList.toggle('active', on);
        el.classList.toggle('bg-ink-900', on);
        el.classList.toggle('text-white', on);
        el.classList.toggle('bg-white', !on);
        el.classList.toggle('text-ink-700', !on);
      });
    }

    function applyFilterSort() {
      const visible = cards.filter((c) => activeFilter === 'all' || c.dataset.subtopic === activeFilter);

      visible.sort((a, b) => {
        if (activeSort === 'newest') return (b.dataset.date || '').localeCompare(a.dataset.date || '');
        if (activeSort === 'oldest') return (a.dataset.date || '').localeCompare(b.dataset.date || '');
        if (activeSort === 'az')     return (a.dataset.title || '').localeCompare(b.dataset.title || '');
        if (activeSort === 'za')     return (b.dataset.title || '').localeCompare(a.dataset.title || '');
        return 0;
      });

      cards.forEach((c) => {
        c.style.display = visible.includes(c) ? '' : 'none';
      });
      visible.forEach((c) => grid.appendChild(c));

      noRes?.classList.toggle('hidden', visible.length > 0);
      if (counter) {
        counter.textContent = visible.length === cards.length
          ? `${cards.length} articles`
          : `${visible.length} of ${cards.length} articles`;
      }
    }

    document.querySelectorAll('.filter-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        activeFilter = btn.dataset.filter || 'all';
        setActiveButton(activeFilter);
        applyFilterSort();
      });
    });

    if (sortSel) {
      sortSel.addEventListener('change', () => {
        activeSort = sortSel.value;
        applyFilterSort();
      });
    }

    if (activeFilter !== 'all') setActiveButton(activeFilter);
    applyFilterSort();
  })();
</script>
