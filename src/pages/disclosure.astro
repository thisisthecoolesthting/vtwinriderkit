---
import CompliantLayout from '@/layouts/CompliantLayout.astro';
import PageIntro from '@/components/PageIntro.astro';
---

<CompliantLayout title="Partner Disclosure" sectionAds="legal">
  <PageIntro eyebrow="Transparency" title="Partner disclosure" description="How affiliate links work on V-Twin Rider Kit — and what we will not do for money." />

  <section class="max-w-site mx-auto px-4 sm:px-6 lg:px-8 pb-14">
    <article class="content-panel max-w-prose mx-auto prose prose-lg prose-ink">
      <p class="!mt-0">
        <strong>As an Amazon Associate I earn from qualifying purchases.</strong>
      </p>
      <p>
        V-Twin Rider Kit is a participant in the Amazon Services LLC Associates
        Program. We may earn a commission when you buy through our links. Your
        price does not change.
      </p>
      <p>
        We are not affiliated with, endorsed by, or sponsored by Harley-Davidson,
        Inc. or any motorcycle manufacturer. Product fitment must be verified
        with the seller before purchase.
      </p>
      <p>
        We do not accept payment to rank products. Commissions do not change
        our editorial order or checklist criteria.
      </p>
      <p>
        Questions: <a href="mailto:hello@vtwinriderkit.org">hello@vtwinriderkit.org</a>.
      </p>
    </article>
  </section>
</CompliantLayout>
