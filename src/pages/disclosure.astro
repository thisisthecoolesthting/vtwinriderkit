---
import CompliantLayout from '@/layouts/CompliantLayout.astro';
import PageIntro from '@/components/PageIntro.astro';
---

<CompliantLayout title="Partner Disclosure" sectionAds="legal">
  <PageIntro eyebrow="Transparency" title="Partner disclosure" description="How affiliate links work on RefillWatch — and what we will not do for money." />

  <section class="max-w-site mx-auto px-4 sm:px-6 lg:px-8 pb-14">
    <article class="content-panel max-w-prose mx-auto prose prose-lg prose-ink">
      <p class="!mt-0">
        RefillWatch is a participant in the Amazon Services LLC Associates
        Program, a partner advertising program designed to provide a means for
        sites to earn advertising fees by advertising and linking to Amazon.com.
      </p>
      <p>
        We also participate in other retailer partner programs from time to time
        (Rakuten, Impact, ShareASale, brand-direct). Whenever we link to a
        product, we may earn a small commission if you click and buy. Your
        price doesn&rsquo;t change.
      </p>
      <p>
        We never accept payment to recommend a product. We&rsquo;ve turned down
        paid sponsorships and undisclosed partner deals because they
        compromise the only thing we have: your trust.
      </p>
      <p>
        If you have questions about any specific recommendation, please
        reach out: <a href="mailto:hello@refillwatch.org">hello@refillwatch.org</a>.
      </p>
    </article>
  </section>
</CompliantLayout>
