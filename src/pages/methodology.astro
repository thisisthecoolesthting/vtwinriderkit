---
import CompliantLayout from '@/layouts/CompliantLayout.astro';
import PageIntro from '@/components/PageIntro.astro';
import home from '@/data/spawn-home.json';

const b = home.brand;
const editorial = (home as { editorial?: { methodology?: string[]; author_slug?: string } }).editorial;
const defaultAuthorSlug = (home as { defaultAuthorSlug?: string }).defaultAuthorSlug || 'jake-morales-vtwinriderkit';
const leadAuthorSlug = editorial?.author_slug || defaultAuthorSlug;
const methodology = (editorial?.methodology || []).filter(Boolean);
const supportEmail = (home as { supportEmail?: string }).supportEmail || 'hello@vtwinriderkit.org';
---

<CompliantLayout
  title="How V-Twin Rider Kit researches and recommends"
  description="How V-Twin Rider Kit evaluates cruiser and touring gear, handles Amazon links, and keeps editorial decisions independent."
  sectionAds="legal"
>
  <PageIntro
    eyebrow="Methodology"
    title="How we research, test, and recommend"
    description="Practical buyer guides for V-twin riders — fitment notes, honest comparisons, and no pay-to-play rankings."
  />

  <section class="max-w-site mx-auto px-4 sm:px-6 lg:px-8 pb-14 md:pb-20">
    <article class="content-panel max-w-prose mx-auto prose prose-lg prose-ink">
      <p class="!mt-0">
        <strong>As an Amazon Associate I earn from qualifying purchases.</strong>
      </p>
      <p>
        We are not affiliated with, endorsed by, or sponsored by Harley-Davidson, Inc. or any
        motorcycle manufacturer.
      </p>

      <h2>Our mission</h2>
      <p>
        {b.fullName} exists because cruiser and touring riders deserve organized, road-tested gear
        lists — not scattered forum threads and dealer upsells. We document what we pack, what we
        wrench with, and what survives long hauls on American V-twins.
      </p>

      <h2>How we evaluate gear</h2>
      {methodology.length > 0 ? (
        <ul>
          {methodology.map((item) => <li>{item}</li>)}
        </ul>
      ) : (
        <ul>
          <li>We prioritize gear with verified cruiser/touring fitment notes in listing text.</li>
          <li>We do not publish live Amazon prices unless pulled from approved catalog data at build time.</li>
          <li>We re-check top picks quarterly and remove discontinued ASINs.</li>
          <li>Reader fitment corrections are updated within 72 hours.</li>
        </ul>
      )}

      <h2>Editorial standards</h2>
      <ul>
        <li>
          <strong>No sponsored placements.</strong> We do not accept payment to rank products or
          change checklist order.
        </li>
        <li>
          <strong>Partner links are disclosed.</strong> Commissions do not change what we recommend.
          See our <a href="/disclosure/">affiliate disclosure</a>.
        </li>
        <li>
          <strong>Human review before publish.</strong> Every piece is reviewed and edited by{' '}
          <a href={`/authors/${leadAuthorSlug}/`}>our editorial lead</a> before it ships.
        </li>
      </ul>

      <h2>Corrections</h2>
      <p>
        Wrong fitment note? Discontinued ASIN? Email{' '}
        <a href={`mailto:${supportEmail}`}>{supportEmail}</a>. We correct fast and note material
        changes on the page.
      </p>

      <h2>What {b.fullName} is not</h2>
      <p>
        Consumer gear journalism — not mechanical, legal, or safety certification advice. Verify
        compatibility with your bike and local regulations before you ride or buy.
      </p>
    </article>
  </section>
</CompliantLayout>
